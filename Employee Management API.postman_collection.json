    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = JSON.parse(pm.response.text());\r",
              "\r",
              " if(jsonData[\"status\"] == 200){\r",
              "    var token =jsonData.data.accessToken;\r",
              "    pm.collectionVariables.set(\"Bearer\", token);\r",
              "    // console.info(pm.collectionVariables.get(\"Bearer\"));\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"userName\": \"admin@employeemanagement.com\",\r\n    \"password\": \"Admin123!\"\r\n}\r\n\r\n// {\r\n// //     \"userName\": \"user@employeemanagement.com\",\r\n//     \"password\": \"User123!\"\r\n// }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://localhost:7183/api/v1/auth/login",
          "protocol": "https",
          "host": [
            "localhost"
          ],
          "port": "7183",
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Employee",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// ============================================\r",
              "// RANDOM NUMBER GENERATOR (1-4)\r",
              "// ============================================\r",
              "\r",
              "function getRandomInt(min, max) {\r",
              "    // Ensure we're working with integers\r",
              "    min = Math.ceil(min);\r",
              "    max = Math.floor(max);\r",
              "    \r",
              "    // Generate random integer\r",
              "    // Math.random() returns 0 to 0.999...\r",
              "    // Multiply by range length, add min, then floor\r",
              "    return Math.floor(Math.random() * (max - min + 1)) + min;\r",
              "}\r",
              "\r",
              "// Generate a random number between 1 and 4\r",
              "var randomNumber = getRandomInt(1, 4);\r",
              "\r",
              "// Store the generated number as a collection variable\r",
              "// You can change this to pm.environment.set() or pm.globals.set() if needed\r",
              "pm.collectionVariables.set(\"randomNumber\", randomNumber);\r",
              "\r",
              "console.log(\"[RANDOM NUMBER GENERATOR] Generated number: \" + randomNumber);\r",
              "\r",
              "\r",
              "// ============================================\r",
              "// USAGE IN BODY:\r",
              "// ============================================\r",
              "// \r",
              "// In your request body (JSON format example):\r",
              "// {\r",
              "//     \"fieldName\": {{randomNumber}}\r",
              "// }\r",
              "//\r",
              "// For form-data or urlencoded:\r",
              "// fieldName = {{randomNumber}}\r",
              "// \r",
              "// ============================================"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"{{$randomFullName}}\",\r\n    \"currentPosition\": {{randomNumber}},\r\n    \"salary\": {{$randomPrice}},\r\n    \"departmentId\": \"BDAFD12B-DAE3-4DCA-A8BD-8BA286EA0530\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://localhost:7183/api/v1/employees",
